# IndiaWish Environment Variables
# Copy this file to .env and fill in the values

# Database
POSTGRES_DB=indiawish
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=Host=localhost;Port=5432;Database=indiawish;Username=postgres;Password=postgres

# JWT
JWT_KEY=IndiaWishSuperSecretKey2024!@#$%^&*()_+SecureEnoughForDevelopment
JWT_ISSUER=IndiaWish
JWT_AUDIENCE=IndiaWishApp
JWT_EXPIRY_MINUTES=15

# Redis
REDIS_CONNECTION_STRING=localhost:6379

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
